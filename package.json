{
  "name": "quickstart-nestjs",
  "version": "0.1.1",
  "description": "Scaffold production-ready NestJS projects with interactive prompts",
  "type": "module",
  "bin": {
    "quickstart-nestjs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/skeletons",
    "src/plugins"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "keywords": [
    "nestjs",
    "scaffold",
    "cli",
    "boilerplate",
    "starter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ejs": "^5.0.1",
    "fs-extra": "^11.3.4",
    "inquirer": "^9.3.8",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
